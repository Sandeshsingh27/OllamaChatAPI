# ── Shared defaults (loaded in every environment) ────────────────────────────
# These can be overridden in .env.development or .env.production.

VITE_APP_TITLE=OllamaChat
VITE_MODEL_NAME=mistral

# API path segments (same in dev and prod — only the base URL differs)
VITE_STREAM_ENDPOINT=/api/chat/stream
VITE_CHAT_ENDPOINT=/api/chat

# Vite dev-server port (used by vite.config.ts — not exposed to the browser bundle)
VITE_DEV_PORT=5173

# Server-side only (never sent to the browser).
# vite.config.ts reads this via loadEnv() to set the proxy target.
BACKEND_URL=http://localhost:8080
