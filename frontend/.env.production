# ── Production environment ────────────────────────────────────────────────────
# Point directly at the Spring Boot server.
# Change the host/port here if you deploy the backend elsewhere.

VITE_API_BASE_URL=http://localhost:8080

# Server-side only — used by vite.config.ts if you run `vite preview`.
# Change to your actual prod server address when deploying.
BACKEND_URL=http://localhost:8080
